# =============================================================================
# BARANGAY DISASTER MONITORING SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# 
# Instructions:
# 1. Copy this file and rename it to .env
# 2. Fill in the empty values with your actual configuration
# 3. Keep .env.example in version control (not .env)
# 4. Never commit actual .env file with real credentials
#
# =============================================================================

# DATABASE CONFIGURATION
# Host: The server where your MySQL database is located
# User: MySQL username with access to the database
# Pass: MySQL password for the user
# Name: Name of the disaster monitoring database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=disaster_monitoring

# SMTP EMAIL CONFIGURATION (Gmail)
# Used for sending email notifications, password resets, and OTP codes
# SMTP_HOST: Gmail SMTP server address
# SMTP_PORT: Gmail SMTP port (usually 587 for TLS)
# SMTP_USERNAME: Your Gmail email address
# SMTP_PASSWORD: Gmail App Password (not regular password - generate from Google Account)
# SMTP_FROM_EMAIL: Email address that will appear as sender
# SMTP_FROM_NAME: Name that will appear as sender
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# APPLICATION CONFIGURATION
# APP_URL: Base URL of the application (without trailing slash)
# APP_NAME: Display name of the application
APP_URL=http://localhost/disaster-report
APP_NAME=Barangay Disaster Monitoring System

# EXPIRY SETTINGS (in minutes)
# OTP_EXPIRY: How long One-Time Passwords remain valid
# RESET_TOKEN_EXPIRY: How long password reset tokens remain valid
OTP_EXPIRY=5
RESET_TOKEN_EXPIRY=5

# TIMEZONE CONFIGURATION
# Set the timezone for the application (PHP timezone identifier)
# Examples: Asia/Manila, America/New_York, Europe/London
# See: https://www.php.net/manual/en/timezones.php
TIMEZONE=Asia/Manila

# GEOAPIFY API CONFIGURATION
# API key for geolocation and mapping services
# Get your free key at: https://www.geoapify.com/
GEOAPIFY_API_KEY= REQUIRED
